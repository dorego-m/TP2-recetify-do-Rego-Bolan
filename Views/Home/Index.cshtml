@{
    ViewData["Title"] = "Home Page";
}

<form action='@Url.Action("GenerarSugerencia", "Home")' method="post">

    <label>Nombre:</label>
    <input type="text" name="Nombre" required />

    <br>

    <label>Fecha de nacimiento:</label>
    <input type="date" name="FechaNacimiento" required />

    <br>

    <label>Tipo de comida:</label>
    <input type="radio" name="TipoComida" value="Caliente" /> Caliente
    <input type="radio" name="TipoComida" value="Fría" />     Fría

    <br>

    <label>Presupuesto:</label>
    <input type="number" name="Presupuesto" min="1" required />

    <br>

    <label>Cantidad de personas:</label>
    <input type="number" name="CantidadPersonas" min="1" max="20" required />

    <br>

    <button type="submit">¡Sugerirme un plato!</button>
</form>